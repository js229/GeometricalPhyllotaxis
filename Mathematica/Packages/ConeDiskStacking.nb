       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"rightQ", "[", 
          RowBox[{"supporters", "[", 
           RowBox[{"[", "2", "]"}], "]"}], "]"}], ",", 
         RowBox[{
          RowBox[{"chainNumbers", "[", 
           RowBox[{"[", 
            RowBox[{"-", "1"}], "]"}], "]"}], "=", 
          RowBox[{"supporters", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"chainNumbers", "=", 
        RowBox[{"dp", "@", 
         RowBox[{"listReplaceRange", "[", 
          RowBox[{"chainNumbers", ",", 
           RowBox[{"supporters", "[", 
            RowBox[{"[", "1", "]"}], "]"}], ",", 
           RowBox[{"supporters", "[", 
            RowBox[{"[", "2", "]"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"supporters", "[", 
              RowBox[{"[", "1", "]"}], "]"}], ",", "ID", ",", 
