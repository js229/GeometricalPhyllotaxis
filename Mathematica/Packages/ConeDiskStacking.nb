         RowBox[{"ID", "===", "0"}], ")"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"dp", "[", "x_", "]"}], " ", ":=", 
        RowBox[{"If", "[", 
         RowBox[{"debug", ",", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Print", "[", "x", "]"}], ";", "x"}], ")"}], ",", "x"}], 
         "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"supporters", "=", 
        RowBox[{"disk", "[", "\"\<Supporters\>\"", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"chainNumbers", "=", 
        RowBox[{"run", "[", "\"\<Chain\>\"", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{"debug", ",", 
         RowBox[{"Print", "[", 
          RowBox[{"\"\<Adding \>\"", ",", " ", 
