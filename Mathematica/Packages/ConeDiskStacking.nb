         ",", 
        RowBox[{"Axes", "->", "True"}], ",", 
        RowBox[{"PlotRange", "->", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "10"}], ",", "10"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"0", ",", "29"}], "}"}]}], "}"}]}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Export", "[", 
      RowBox[{"\"\<graphic.pdf\>\"", ",", "g", ",", 
       RowBox[{"ImageSize", "->", "imageSizeInPoints"}]}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
