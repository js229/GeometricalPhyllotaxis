       "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"g", "=", 
       RowBox[{"removeOldPath", "[", 
        RowBox[{"g", ",", "rightSupporters"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"emptyNodes", "=", 
       RowBox[{"Select", "[", 
        RowBox[{
         RowBox[{"VertexList", "[", "g", "]"}], ",", 
         RowBox[{
          RowBox[{
           RowBox[{"VertexDegree", "[", 
            RowBox[{"g", ",", "#"}], "]"}], "==", "0"}], "&"}]}], "]"}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"g", "=", 
       RowBox[{"VertexDelete", "[", 
        RowBox[{"g", ",", "emptyNodes"}], "]"}]}], ";", "\[IndentingNewLine]",
       "g"}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}], "\[IndentingNewLine]"}], "Input",
 InitializationCell->
  True,ExpressionUUID->"282aeab2-87a1-5149-8f2d-f791fee6847d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"addNodeXY", "[", 
     RowBox[{"graph_", ",", "node_", ",", "xy_"}], "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "g", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"g", "=", "graph"}], ";", "\[IndentingNewLine]", 
       RowBox[{"g", "=", 
        RowBox[{"VertexAdd", "[", 
         RowBox[{"g", ",", "node"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"AnnotationValue", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"g", ",", "node"}], "}"}], ",", "VertexCoordinates"}], 
         "]"}], "=", "xy"}], ";", "\[IndentingNewLine]", "g"}]}], 
     "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"addNodeFromRun", "[", 
     RowBox[{"graph_", ",", "run_", ",", "node_"}], "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"g", ",", "xy"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"g", "=", "graph"}], ";", "\[IndentingNewLine]", 
       RowBox[{"xy", "=", 
        RowBox[{"diskCentre", "[", 
         RowBox[{
          RowBox[{"Lookup", "[", 
           RowBox[{
            RowBox[{"run", "[", "\"\<Disks\>\"", "]"}], ",", "node"}], "]"}], 
          "[", "\"\<Disk\>\"", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"g", "=", 
        RowBox[{"addNodeXY", "[", 
         RowBox[{"g", ",", "node", ",", "xy"}], "]"}]}], ";", 
       "\[IndentingNewLine]", "g"}]}], "\[IndentingNewLine]", "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"updateGraph", "[", 
    RowBox[{"run_", ",", "ID_"}], "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"g", ",", "newNodes", ",", "supporters", ",", "chain"}], "}"}], 
     ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"newNodes", "=", 
       RowBox[{"Complement", "[", 
        RowBox[{
         RowBox[{"run", "[", "\"\<Chain\>\"", "]"}], ",", 
         RowBox[{"VertexList", "[", 
          RowBox[{"run", "[", "\"\<Graph\>\"", "]"}], "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"g", "=", 
       RowBox[{"run", "[", "\"\<Graph\>\"", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"g", "=", 
       RowBox[{"Fold", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"addNodeFromRun", "[", 
           RowBox[{"#1", ",", "run", ",", "#2"}], "]"}], "&"}], ",", "g", ",",
          "newNodes"}], "]"}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"pairs", "=", 
       RowBox[{"Partition", "[", 
        RowBox[{
         RowBox[{"run", "[", "\"\<Chain\>\"", "]"}], ",", "2", ",", "1"}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"edges", "=", 
       RowBox[{"Map", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Apply", "[", 
           RowBox[{"UndirectedEdge", ",", "#"}], "]"}], "&"}], ",", "pairs"}],
         "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"edges", "=", 
       RowBox[{"Complement", "[", 
        RowBox[{"edges", ",", 
         RowBox[{"EdgeList", "[", "g", "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"edges", "=", 
       RowBox[{"Complement", "[", 
        RowBox[{"edges", ",", 
         RowBox[{"Reverse", "/@", 
          RowBox[{"EdgeList", "[", "g", "]"}]}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"g", "=", 
       RowBox[{"EdgeAdd", "[", 
        RowBox[{"g", ",", "edges"}], "]"}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", "g"}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}], "\[IndentingNewLine]"}], "Input",
 InitializationCell->
  True,ExpressionUUID->"7d87720b-62fa-8b4e-a16b-02f23c3a5c34"],

Cell[BoxData[
 RowBox[{
  RowBox[{"tangentDiskCentres", "[", 
   RowBox[{"c1_List", ",", "c2_List", ",", "R_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"mid", ",", "diff", ",", "d", ",", "h", ",", "unitPerp"}], "}"}],
     ",", 
    RowBox[{"(*", 
     RowBox[{
     "1.", " ", "Vector", " ", "between", " ", "centers", " ", "and", " ", 
      "total", " ", "distance"}], "*)"}], 
    RowBox[{
     RowBox[{"diff", "=", 
      RowBox[{"c2", "-", "c1"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"d", "=", 
      RowBox[{"Norm", "[", "diff", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
      "2.", " ", "Check", " ", "if", " ", "a", " ", "solution", " ", "exists",
        " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"distance", " ", "must", " ", "be"}], "<=", 
         RowBox[{"4", "R"}]}], ")"}]}], "*)"}], 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"d", ">", 
        RowBox[{"4", "*", "R"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{
         "Print", 
          "[", "\"\<No solution: Centers are too far apart (d > 4R)\>\"", 
          "]"}], ";"}], "\[IndentingNewLine]", "*)"}], 
       RowBox[{"Return", "[", 
        RowBox[{"Missing", "[", "]"}], "]"}]}], "\[IndentingNewLine]", "]"}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
      "3.", " ", "Midpoint", " ", "and", " ", "the", " ", "height", " ", "of",
        " ", "the", " ", "triangle", " ", "from", " ", "midpoint", " ", "to", 
       " ", "c3"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"mid", "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"c1", "+", "c2"}], ")"}], "/", "2"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"h", "=", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"4", "*", 
         RowBox[{"R", "^", "2"}]}], "-", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"d", "/", "2"}], ")"}], "^", "2"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
      "4.", " ", "Find", " ", "the", " ", "unit", " ", "vector", " ", 
       "perpendicular", " ", "to", " ", "the", " ", "line", " ", "connecting",
        " ", "c1", " ", "and", " ", "c2"}], "*)"}], 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"Standard", " ", "2", "D", " ", 
        RowBox[{"rotation", ":", 
         RowBox[{"{", 
          RowBox[{"x", ",", "y"}], "}"}]}]}], "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "y"}], ",", "x"}], "}"}]}], "*)"}], 
     RowBox[{"unitPerp", "=", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"diff", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], ",", 
         RowBox[{"diff", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], "}"}], "/", "d"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
      "5.", " ", "Return", " ", "the", " ", "two", " ", "possible", " ", 
       "centers"}], "*)"}], 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"mid", "+", 
        RowBox[{"h", "*", "unitPerp"}]}], ",", 
       RowBox[{"mid", "-", 
        RowBox[{"h", "*", "unitPerp"}]}]}], "}"}]}]}], "]"}]}]], "Input",
 InitializationCell->True,
 CellLabel->"In[84]:=",ExpressionUUID->"367c735a-29ec-a740-b1de-f29038a37faa"]
},
