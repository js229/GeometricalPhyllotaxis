Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"lowestTangentDiskFromPairs", "[", 
    RowBox[{"run_", ",", "ID_"}], "]"}], ":=", " ", "\[IndentingNewLine]", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "choices", ",", "arena", ",", "chainDisks", ",", "ixPairs", ",", 
       "lowest"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"arena", "=", 
       RowBox[{"run", "[", "\"\<Arena\>\"", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"chainDisks", "=", 
       RowBox[{"KeyTake", "[", 
        RowBox[{
         RowBox[{"run", "[", "\"\<Disks\>\"", "]"}], ",", 
         RowBox[{"run", "[", "\"\<Chain\>\"", "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"ixPairs", "=", 
       RowBox[{"Subsets", "[", 
        RowBox[{
         RowBox[{"run", "[", "\"\<Chain\>\"", "]"}], ",", 
         RowBox[{"{", "2", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"choices", "=", 
       RowBox[{"findTangentDisks", "[", 
        RowBox[{"arena", ",", "chainDisks", ",", "ixPairs"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"choices", "=", 
       RowBox[{"Select", "[", 
        RowBox[{"choices", ",", 
         RowBox[{
          RowBox[{"!", 
           RowBox[{"MissingQ", "[", "#Disk", "]"}]}], "&"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"choices", "=", 
       RowBox[{"Map", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Append", "[", 
           RowBox[{"#", ",", 
            RowBox[{"\"\<Polar\>\"", "->", 
             RowBox[{"disk2Polar", "[", "#Disk", "]"}]}]}], "]"}], "&"}], ",",
          "choices"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"choices", "=", 
       RowBox[{"pruneTangentDisks", "[", 
        RowBox[{"arena", ",", "chainDisks", ",", "choices"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"choices", "=", 
       RowBox[{"SortBy", "[", 
        RowBox[{"choices", ",", 
         RowBox[{
          RowBox[{
           RowBox[{"#", "[", "\"\<Polar\>\"", "]"}], "[", "\"\<r\>\"", "]"}], 
          "&"}]}], "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"lowest", "=", 
       RowBox[{"First", "[", "choices", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"lowest", "=", 
       RowBox[{"Prepend", "[", 
        RowBox[{"lowest", ",", 
         RowBox[{"\"\<ID\>\"", "->", "ID"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"lowest", "[", "\"\<InCone\>\"", "]"}], 
         "==", "\"\<Left\>\""}], ",", "\[IndentingNewLine]", 
        RowBox[{"lowest", "=", 
         RowBox[{"rightShift", "[", 
          RowBox[{"arena", ",", "lowest"}], "]"}]}]}], "\[IndentingNewLine]", 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"lowest", "[", "\"\<InCone\>\"", "]"}], 
         "==", "\"\<Right\>\""}], ",", "\[IndentingNewLine]", 
        RowBox[{"lowest", "=", 
         RowBox[{"leftShift", "[", 
          RowBox[{"arena", ",", "lowest"}], "]"}]}]}], "\[IndentingNewLine]", 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"lowest", "[", "\"\<ID\>\"", "]"}], "=", "ID"}], ";", 
      "\[IndentingNewLine]", "lowest"}]}], "\[IndentingNewLine]", 
    "]"}]}]}]], "Input",
