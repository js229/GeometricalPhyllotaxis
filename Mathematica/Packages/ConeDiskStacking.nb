Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"doParameterisedRun", "[", "arena_", "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"runDisks", "=", 
       RowBox[{"initalizeDisks", "[", "arena", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"runChain", "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"left", "[", "1", "]"}], ",", "1", ",", 
         RowBox[{"right", "[", "1", "]"}]}], "}"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"run", "=", 
       RowBox[{"<|", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"\"\<Arena\>\"", "->", "arena"}], ",", "\[IndentingNewLine]", 
         RowBox[{"\"\<Disks\>\"", "->", "runDisks"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"\"\<Chain\>\"", "->", "runChain"}], ",", 
         "\[IndentingNewLine]", 
         RowBox[{"\"\<ID\>\"", "->", "1"}], ",", "\[IndentingNewLine]", 
         RowBox[{"\"\<Logging\>\"", "->", 
          RowBox[{"<|", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"\"\<ID\>\"", "->", "1"}], ",", "\[IndentingNewLine]", 
            RowBox[{"\"\<Disks\>\"", "->", 
             RowBox[{"<|", "|>"}]}], ",", "\[IndentingNewLine]", 
            RowBox[{"\"\<ChainStore\>\"", "->", 
             RowBox[{"{", "runChain", "}"}]}], ",", "\[IndentingNewLine]", 
            RowBox[{"\"\<ParastichyCount\>\"", "->", 
             RowBox[{"<|", 
              RowBox[{"1", "->", 
               RowBox[{"<|", 
                RowBox[{
                 RowBox[{"\"\<Up\>\"", "->", "1"}], ",", 
                 RowBox[{"\"\<Down\>\"", "->", "1"}]}], "|>"}]}], "|>"}]}], ",",
             "\[IndentingNewLine]", 
            RowBox[{"\"\<rMax\>\"", "->", "\"\<Missing\>\""}]}], 
           "\[IndentingNewLine]", "|>"}]}]}], "\[IndentingNewLine]", "|>"}]}],
       ";", "\[IndentingNewLine]", 
      RowBox[{"run", "=", 
       RowBox[{"logStep", "[", 
        RowBox[{"run", ",", "0"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"run", "=", 
       RowBox[{"restartRun", "[", "run", "]"}]}], ";", "\[IndentingNewLine]", 
      "run"}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"logStep", "[", 
    RowBox[{"run_", ",", "timing_"}], "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"res", ",", "thisLog", ",", "elapsed"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"res", "=", "run"}], ";", "\[IndentingNewLine]", 
      RowBox[{"thisLog", "=", 
       RowBox[{"res", "[", "\"\<Logging\>\"", "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"elapsed", "=", 
       RowBox[{"Round", "@", 
        RowBox[{"Abs", "@", 
         RowBox[{"DateDifference", "[", 
          RowBox[{"Now", ",", "globalTime", ",", "\"\<Second\>\""}], 
          "]"}]}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"thisLog", "[", "\"\<ElapsedSeconds\>\"", "]"}], "=", 
       RowBox[{"Round", "@", 
        RowBox[{"Abs", "@", 
         RowBox[{"DateDifference", "[", 
          RowBox[{"Now", ",", "globalTime", ",", "\"\<Second\>\""}], 
          "]"}]}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"thisLog", "[", "\"\<TimingMicroSeconds\>\"", "]"}], "=", 
       RowBox[{"Round", "[", 
        RowBox[{"1000", "*", "timing"}], "]"}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"thisLog", "[", "\"\<ID\>\"", "]"}], "=", 
       RowBox[{"run", "[", "\"\<ID\>\"", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"thisLog", "[", "\"\<Disks\>\"", "]"}], "=", 
       RowBox[{"Append", "[", 
        RowBox[{
         RowBox[{"thisLog", "[", "\"\<Disks\>\"", "]"}], ",", 
         RowBox[{"run", "[", "\"\<Disks\>\"", "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"thisLog", "[", "\"\<ChainStore\>\"", "]"}], "=", 
       RowBox[{"Append", "[", 
        RowBox[{
         RowBox[{"thisLog", "[", "\"\<ChainStore\>\"", "]"}], ",", 
         RowBox[{"run", "[", "\"\<Chain\>\"", "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"res", "[", "\"\<Logging\>\"", "]"}], "=", "thisLog"}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "computeParastichy", " ", "needs", " ", "the", " ", "disks", " ", "in",
         " ", 
        RowBox[{
         RowBox[{"res", "[", "\"\<Logging\>\"", "]"}], "[", "\"\<Disks\>\"", 
         "]"}]}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"thisLog", "[", "\"\<ParastichyCount\>\"", "]"}], " ", "=", 
       RowBox[{"Append", "[", 
        RowBox[{
         RowBox[{"thisLog", "[", "\"\<ParastichyCount\>\"", "]"}], " ", ",", 
         RowBox[{
          RowBox[{"res", "[", "\"\<ID\>\"", "]"}], "->", 
          RowBox[{"computeParastichy", "[", "res", "]"}]}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"res", "[", "\"\<Logging\>\"", "]"}], "=", "thisLog"}], ";", 
      "\[IndentingNewLine]", "res"}]}], "\[IndentingNewLine]", "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"monitoringString", "[", "run_", "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
      "StringTemplate", "[", 
       "\[IndentingNewLine]", "\"\< `ID` \\t`Parastichy pair` \\tElapsed \
`ElapsedSeconds`\\tTiming `TimingMicroSeconds`\>\"", "]"}], 
      "\[IndentingNewLine]", "[", 
      RowBox[{"Append", "[", 
       RowBox[{
        RowBox[{"run", "[", "\"\<Logging\>\"", "]"}], ",", 
        RowBox[{"\"\<Parastichy pair\>\"", "->", 
         RowBox[{"Last", "@", 
          RowBox[{
           RowBox[{"run", "[", "\"\<Logging\>\"", "]"}], 
           "[", "\"\<ParastichyCount\>\"", "]"}]}]}]}], "]"}], "]"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]}], "Input",
 InitializationCell->True,
 CellLabel->
  "In[269]:=",ExpressionUUID->"48ef3d46-2241-794c-8678-8b2b746f3bb8"],

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"addLowest", "[", "run_", "]"}], " ", ":=", " ", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "res", ",", "ixPairs", ",", "ID", ",", "ids", ",", "diskData", ",", 
         "disks", ",", "timing", ",", "monitorResults"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"res", "=", "run"}], ";", "\[IndentingNewLine]", 
        RowBox[{"ID", "=", 
         RowBox[{
          RowBox[{"run", "[", "\"\<ID\>\"", "]"}], "+", "1"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"res", "[", "\"\<ID\>\"", "]"}], "=", "ID"}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"timing", ",", "diskData"}], "}"}], "=", 
         RowBox[{"Timing", "[", 
          RowBox[{"lowestTangentDiskFromPairs", "[", 
           RowBox[{"res", ",", "ID"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"res", "[", "\"\<Disks\>\"", "]"}], "=", " ", 
         RowBox[{"addDisk", "[", 
          RowBox[{
           RowBox[{"res", "[", "\"\<Arena\>\"", "]"}], ",", 
           RowBox[{"res", "[", "\"\<Disks\>\"", "]"}], ",", "diskData", ",", 
           "ID"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"res", "[", "\"\<Chain\>\"", "]"}], "=", " ", 
         RowBox[{"updateChain", "[", 
          RowBox[{"res", ",", "diskData"}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"clearOldDisksFromCache", "[", "res", "]"}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{
          "if", " ", "the", " ", "new", " ", "disk", " ", "has", " ", "a", " ",
            "supporter", " ", "which", " ", "is", " ", "a", " ", 
           RowBox[{"left", "[", "n", "]"}], " ", "or", " ", 
           RowBox[{"right", "[", "n", "]"}], " ", "that", " ", "might", " ", 
           "not", " ", "have", " ", "been", " ", "in", " ", "the", " ", 
           "Disks", " ", "before"}], ",", " ", 
          RowBox[{
          "because", " ", "it", " ", "was", " ", "only", " ", "there", " ", 
           "as", " ", "n"}]}], "   ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"ids", "=", 
         RowBox[{"Complement", "[", 
          RowBox[{
           RowBox[{"res", "[", "\"\<Chain\>\"", "]"}], ",", 
           RowBox[{"Keys", "[", 
            RowBox[{"res", "[", "\"\<Disks\>\"", "]"}], "]"}]}], "]"}]}], ";",
         "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"res", "[", "\"\<Disks\>\"", "]"}], "=", 
         RowBox[{"Fold", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"addLRDisk", "[", 
             RowBox[{
              RowBox[{"res", "[", "\"\<Arena\>\"", "]"}], ",", "#1", ",", 
              "#2"}], "]"}], "&"}], ",", 
           RowBox[{"res", "[", "\"\<Disks\>\"", "]"}], ",", "ids"}], "]"}]}], 
        ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"res", "=", 
         RowBox[{"logStep", "[", 
          RowBox[{"res", ",", "timing"}], "]"}]}], ";", "\[IndentingNewLine]",
         "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{"having", " ", "logged", " ", "past", " ", "disks"}], ",", 
          " ", 
          RowBox[{
          "only", " ", "use", " ", "current", " ", "chain", " ", "for", " ", 
           "lookup"}]}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"res", "[", "\"\<Disks\>\"", "]"}], "=", 
         RowBox[{"KeyTake", "[", 
          RowBox[{
           RowBox[{"res", "[", "\"\<Disks\>\"", "]"}], ",", 
           RowBox[{"Append", "[", 
            RowBox[{
             RowBox[{"res", "[", "\"\<Chain\>\"", "]"}], ",", "ids"}], 
            "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
        "\[IndentingNewLine]", 
        RowBox[{"monitorString", "=", 
         RowBox[{"monitoringString", "[", "res", "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", "res"}]}], 
      "\[IndentingNewLine]", "\[IndentingNewLine]", "]"}]}], ";"}], 
   "\[IndentingNewLine]"}]}]], "Input",
 InitializationCell->True,
 CellLabel->
  "In[184]:=",ExpressionUUID->"f2c38ad1-940d-7545-9f35-d50ded8a03f0"],

Cell[CellGroupData[{

Cell["Computation: fixed radius disk on cone", "Subtitle",ExpressionUUID->"62d97471-3ff2-2544-9c4e-d94352b2cf58"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"initalizeDisks", "[", "arena_", "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"initialDisks", ",", "d"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"d", "=", 
        RowBox[{"N", "[", 
         RowBox[{
          RowBox[{"arena", "[", "\"\<DiskRadius\>\"", "]"}], "/", 
          RowBox[{"Sin", "[", 
           RowBox[{"arena", "[", "\"\<ConeSemiAngle\>\"", "]"}], "]"}]}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"initialDisks", "=", 
        RowBox[{"<|", 
         RowBox[{"1", "->", 
          RowBox[{"<|", 
           RowBox[{
            RowBox[{"\"\<ID\>\"", "->", "1"}], ",", 
            RowBox[{"\"\<Disk\>\"", "->", 
             RowBox[{"Disk", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"0", ",", "d"}], "}"}], ",", 
               RowBox[{"arena", "[", "\"\<DiskRadius\>\"", "]"}]}], "]"}]}], 
            "\[IndentingNewLine]", ",", 
            RowBox[{"\"\<Polar\>\"", "->", 
             RowBox[{"<|", 
              RowBox[{
               RowBox[{"\"\<r\>\"", "->", "d"}], ",", 
               RowBox[{"\"\<\[Theta]\>\"", "->", 
                RowBox[{"\[Pi]", "/", "2"}]}]}], "|>"}]}], 
            "\[IndentingNewLine]", ",", 
            RowBox[{"\"\<Supporters\>\"", "->", 
             RowBox[{"Missing", "[", "]"}]}], "\[IndentingNewLine]", ",", 
            RowBox[{"\"\<EdgeDisk\>\"", "->", 
             RowBox[{"<|", 
              RowBox[{
               RowBox[{"\"\<Left\>\"", "->", "True"}], ",", 
               RowBox[{"\"\<Right\>\"", "->", "True"}]}], "|>"}]}], 
            "\[IndentingNewLine]", ",", 
            RowBox[{"\"\<CanSupportDisk\>\"", "->", 
             RowBox[{"<|", 
              RowBox[{
               RowBox[{"\"\<Left\>\"", "->", "True"}], ",", 
               RowBox[{"\"\<Right\>\"", "->", "True"}]}], "|>"}]}]}], 
           "\[IndentingNewLine]", "|>"}]}], "|>"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"initialDisks", "=", 
        RowBox[{"addLRDisk", "[", 
         RowBox[{"arena", ",", "initialDisks", ",", 
          RowBox[{"left", "[", "1", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"initialDisks", "=", 
        RowBox[{"addLRDisk", "[", 
         RowBox[{"arena", ",", "initialDisks", ",", 
          RowBox[{"right", "[", "1", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", "initialDisks"}]}], "\[IndentingNewLine]", 
     "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]"}]], "Input",
 InitializationCell->True,
 CellLabel->
  "In[185]:=",ExpressionUUID->"c4e40b84-a7d6-f747-84af-1049b88bd88c"],

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"addDisk", "[", 
      RowBox[{"arena_", ",", "disks_", ",", "disk_", ",", "ID_"}], "]"}], " ",
      ":=", " ", 
     RowBox[{"Append", "[", 
      RowBox[{"disks", ",", 
       RowBox[{"ID", "->", "disk"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"addLRDisk", "[", 
      RowBox[{"arena_", ",", "disks_", ",", 
       RowBox[{"left", "[", "ID_", "]"}]}], "]"}], " ", ":=", " ", 
     RowBox[{"Append", "[", 
      RowBox[{"disks", ",", 
       RowBox[{
        RowBox[{"left", "[", "ID", "]"}], "->", 
        RowBox[{"leftShift", "[", 
         RowBox[{"arena", ",", 
          RowBox[{"Lookup", "[", 
           RowBox[{"disks", ",", "ID"}], "]"}]}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"addLRDisk", "[", 
     RowBox[{"arena_", ",", "disks_", ",", 
      RowBox[{"right", "[", "ID_", "]"}]}], "]"}], " ", ":=", " ", 
    RowBox[{"Append", "[", 
     RowBox[{"disks", ",", 
      RowBox[{
       RowBox[{"right", "[", "ID", "]"}], "->", 
       RowBox[{"rightShift", "[", 
        RowBox[{"arena", ",", 
         RowBox[{"Lookup", "[", 
          RowBox[{"disks", ",", "ID"}], "]"}]}], "]"}]}]}], 
     "]"}]}]}]}]], "Input",
 InitializationCell->True,
 CellLabel->
