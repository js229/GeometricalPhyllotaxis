   RowBox[{
    RowBox[{"diskIDDiskDistance", "[", 
     RowBox[{"arena_", ",", "disks_", ",", "disk_"}], "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"c1", ",", "diskCentres", ",", "cLeft", ",", "cRight"}], "}"}],
       ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"c1", "=", 
        RowBox[{"diskCentre", "[", 
         RowBox[{"disk", "[", "\"\<Disk\>\"", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"cLeft", "=", 
        RowBox[{"leftShift", "[", 
         RowBox[{"arena", ",", "c1"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"cRight", "=", 
        RowBox[{"rightShift", "[", 
         RowBox[{"arena", ",", "c1"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"diskCentres", "=", 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"diskIDCentre", "[", 
            RowBox[{"disks", ",", "#"}], "]"}], "&"}], ",", 
          RowBox[{"Keys", "[", "disks", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Min", "@", 
        RowBox[{"Flatten", "[", 
         RowBox[{"{", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Map", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Norm", "[", 
               RowBox[{"#", "-", "c1"}], "]"}], "&"}], ",", "diskCentres"}], 
            "]"}], ",", 
           RowBox[{"Map", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Norm", "[", 
               RowBox[{"#", "-", "cLeft"}], "]"}], "&"}], ",", 
             "diskCentres"}], "]"}], ",", 
           RowBox[{"Map", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Norm", "[", 
               RowBox[{"#", "-", "cRight"}], "]"}], "&"}], ",", 
             "diskCentres"}], "]"}]}], "\[IndentingNewLine]", "}"}], 
         "\[IndentingNewLine]", "]"}]}]}]}], "\[IndentingNewLine]", "]"}]}], 
   ";"}], "\[IndentingNewLine]"}]], "Input",
 InitializationCell->True,
 CellLabel->
  "In[253]:=",ExpressionUUID->"a41ed514-5b33-904d-a6dd-115bbb1c1933"],

Cell[BoxData[
 RowBox[{
  RowBox[{"tangentDiskCentres", "[", 
   RowBox[{"c1_List", ",", "c2_List", ",", "R_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "mid", ",", "diff", ",", "d", ",", "h", ",", "hSquared", ",", 
      "unitPerp"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
     "1.", " ", "Vector", " ", "between", " ", "centers", " ", "and", " ", 
      "total", " ", "distance"}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"diff", "=", 
      RowBox[{"c2", "-", "c1"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"d", "=", 
      RowBox[{"Norm", "[", "diff", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Chop", "[", "d", "]"}], "==", "0"}], ",", 
       RowBox[{
        RowBox[{"Print", "[", 
         RowBox[{"\"\<tDC Identical \>\"", ",", "c1"}], "]"}], ";", 
        RowBox[{"Return", "[", 
         RowBox[{"Missing", "[", "\"\<Identical\>\"", "]"}], "]"}]}]}], "]"}],
      ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
      "2.", " ", "Check", " ", "if", " ", "a", " ", "solution", " ", "exists",
        " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"distance", " ", "must", " ", "be"}], "<=", 
         RowBox[{"4", "R"}]}], ")"}]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"hSquared", "=", 
      RowBox[{
       RowBox[{"4", "*", 
        RowBox[{"R", "^", "2"}]}], "-", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"d", "/", "2"}], ")"}], "^", "2"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"hSquared", "<", "0"}], ",", "\[IndentingNewLine]", 
       RowBox[{"Return", "[", 
        RowBox[{"Missing", "[", "]"}], "]"}]}], "\[IndentingNewLine]", "]"}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
      "3.", " ", "Midpoint", " ", "and", " ", "the", " ", "height", " ", "of",
        " ", "the", " ", "triangle", " ", "from", " ", "midpoint", " ", "to", 
       " ", "c3"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"mid", "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"c1", "+", "c2"}], ")"}], "/", "2"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"h", "=", 
      RowBox[{"Sqrt", "[", "hSquared", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
      "4.", " ", "Find", " ", "the", " ", "unit", " ", "vector", " ", 
       "perpendicular", " ", "to", " ", "the", " ", "line", " ", "connecting",
        " ", "c1", " ", "and", " ", "c2"}], "*)"}], 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"Standard", " ", "2", "D", " ", 
        RowBox[{"rotation", ":", 
         RowBox[{"{", 
          RowBox[{"x", ",", "y"}], "}"}]}]}], "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "y"}], ",", "x"}], "}"}]}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"unitPerp", "=", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"diff", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], ",", 
         RowBox[{"diff", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], "}"}], "/", "d"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
      "5.", " ", "Return", " ", "the", " ", "two", " ", "possible", " ", 
       "centers"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"mid", "+", 
        RowBox[{"h", "*", "unitPerp"}]}], ",", 
       RowBox[{"mid", "-", 
        RowBox[{"h", "*", "unitPerp"}]}]}], "}"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 InitializationCell->True,
 CellLabel->
  "In[254]:=",ExpressionUUID->"367c735a-29ec-a740-b1de-f29038a37faa"]
}, Open  ]],

