            ",", "supporters"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"from", ">", "to"}], ",", 
         RowBox[{"supporters", "=", 
          RowBox[{"Reverse", "[", "supporters", "]"}]}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"leftQ", "[", 
          RowBox[{"supporters", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "]"}], ",", 
         RowBox[{
          RowBox[{"chainNumbers", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "=", 
