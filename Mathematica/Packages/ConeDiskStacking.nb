              RowBox[{"[", "2", "]"}], "]"}]}], "}"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"rightQ", "[", 
          RowBox[{"supporters", "[", 
           RowBox[{"[", "2", "]"}], "]"}], "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"chainNumbers", "=", 
           RowBox[{"listReplaceRange", "[", 
            RowBox[{"chainNumbers", ",", 
             RowBox[{"First", "[", "chainNumbers", "]"}], ",", 
             RowBox[{"shiftNumberLeft", "[", 
              RowBox[{"supporters", "[", 
               RowBox[{"[", "2", "]"}], "]"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"shiftNumberLeft", "[", "ID", "]"}], ",", 
               RowBox[{"shiftNumberLeft", "[", 
                RowBox[{"supporters", "[", 
