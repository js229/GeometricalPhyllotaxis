        "res", ",", "ixPairs", ",", "ID", ",", "ids", ",", "diskData", ",", 
         "disks"}], "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"res", "=", "run"}], ";", "\[IndentingNewLine]", 
        RowBox[{"ID", "=", 
         RowBox[{"nextID", "[", "res", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"diskData", "=", 
         RowBox[{"lowestTangentDiskFromPairs", "[", 
          RowBox[{"res", ",", "ID"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"res", "[", "\"\<Disks\>\"", "]"}], "=", " ", 
         RowBox[{"addDisk", "[", 
          RowBox[{
