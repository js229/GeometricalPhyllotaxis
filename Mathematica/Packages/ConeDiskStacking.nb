Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"testArena", "[", "n_", "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"arena", ",", "\[Theta]"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"\[Theta]", "=", 
        RowBox[{"N", "[", 
         RowBox[{"\[Pi]", "/", "8"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"arena", "=", 
        RowBox[{"<|", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"\"\<Type\>\"", "->", "\"\<Cone\>\""}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"\"\<DiskRadius\>\"", "->", "1"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"\"\<ConeSemiAngle\>\"", "->", "\[Theta]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"\"\<Edges\>\"", "->", 
           RowBox[{"<|", 
            RowBox[{
             RowBox[{"\"\<Left\>\"", "->", 
              RowBox[{"InfiniteLine", "[", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"0", ",", "0"}], "}"}], ",", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"-", 
                    RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", 
                   RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}], "}"}], 
               "]"}]}], ",", 
             RowBox[{"\"\<Right\>\"", "->", 
              RowBox[{"InfiniteLine", "[", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"0", ",", "0"}], "}"}], ",", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"Sin", "[", "\[Theta]", "]"}], ",", 
                   RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}], "}"}], 
               "]"}]}]}], "|>"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{"\"\<zRange\>\"", "->", 
           RowBox[{"{", 
            RowBox[{"0", ",", "30"}], "}"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{"\"\<IDmax\>\"", "->", "n"}]}], "\[IndentingNewLine]", 
         "|>"}]}], ";", "\[IndentingNewLine]", "arena"}]}], 
     "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]"}]], "Input",
 InitializationCell->True,
 CellLabel->
  "In[171]:=",ExpressionUUID->"c2924e34-f199-8248-abd3-eb73c1ffd8f4"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"restartRun", "[", "lastRun_", "]"}], " ", ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"run", "=", "lastRun"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"run", "[", "\"\<Logging\>\"", "]"}], "[", "\"\<Disks\>\"", 
       "]"}], "=", 
      RowBox[{"<|", "|>"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"run", "[", "\"\<Logging\>\"", "]"}], "[", "\"\<ChainStore\>\"",
        "]"}], " ", "=", " ", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"globalTime", "=", "Now"}], ";", "\[IndentingNewLine]", 
     RowBox[{"globalTangentDiskCache", "=", 
      RowBox[{"<|", "|>"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"monitorString", "=", "\"\<Restart\>\""}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"run", "=", 
      RowBox[{"Monitor", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"NestWhile", "[", "\[IndentingNewLine]", 
         RowBox[{
         "addLowest", ",", "run", ",", "continueCondition", ",", "1", ",", 
          RowBox[{"maxIterations", "=", "1000"}]}], "]"}], ",", 
        "monitorString"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "monitorString", "]"}], ";", "\[IndentingNewLine]",
      "run"}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"continueCondition", "[", "run_", "]"}], " ", ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "diskID", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"diskID", "=", 
      RowBox[{"Max", "[", 
       RowBox[{"Select", "[", 
        RowBox[{
         RowBox[{"Keys", "[", 
          RowBox[{"run", "[", "\"\<Disks\>\"", "]"}], "]"}], ",", "NumberQ"}],
         "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"diskID", ">=", " ", 
        RowBox[{
         RowBox[{"run", "[", "\"\<Arena\>\"", "]"}], "[", "\"\<IDmax\>\"", 
         "]"}]}], ",", " ", 
       RowBox[{"Return", "[", "False", "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", "True", "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]}], "Input",
