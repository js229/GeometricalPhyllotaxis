              "#2"}], "]"}], "&"}], ",", 
           RowBox[{"res", "[", "\"\<Disks\>\"", "]"}], ",", "ids"}], "]"}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"(*", 
