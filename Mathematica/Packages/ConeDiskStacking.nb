      RowBox[{"{", 
       RowBox[{
        RowBox[{"left", "[", "1", "]"}], ",", "1", ",", 
        RowBox[{"right", "[", "1", "]"}]}], "}"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"run", "=", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<Arena\>\"", "->", "arena"}], ",", 
        RowBox[{"\"\<Disks\>\"", "->", "runDisks"}], ",", 
        RowBox[{"\"\<Chain\>\"", "->", "runChain"}]}], "|>"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"run", "=", 
      RowBox[{"Nest", "[", 
       RowBox[{"addLowest", ",", "run", ",", "n"}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"displayRun", "[", "run", "]"}]}]}], "\[IndentingNewLine]", 
