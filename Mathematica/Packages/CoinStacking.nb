               RowBox[{"\"\<Right\>\"", "->", "True"}]}], "|>"}]}]}], 
           "\[IndentingNewLine]", "|>"}]}], "|>"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"initialDisks", "=", 
        RowBox[{"addLRDisk", "[", 
         RowBox[{"arena", ",", "initialDisks", ",", 
          RowBox[{"left", "[", "1", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"initialDisks", "=", 
        RowBox[{"addLRDisk", "[", 
         RowBox[{"arena", ",", "initialDisks", ",", 
          RowBox[{"right", "[", "1", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", "initialDisks"}]}], "\[IndentingNewLine]", 
