Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"initalizeDisks", "[", "arena_", "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"initialDisks", ",", "d"}], "}"}], ",", "\[IndentingNewLine]", 
      
      RowBox[{
       RowBox[{"d", "=", 
        RowBox[{"N", "[", 
         RowBox[{
          RowBox[{"arena", "[", "\"\<DiskRadius\>\"", "]"}], "/", 
          RowBox[{"Sin", "[", 
           RowBox[{"arena", "[", "\"\<ConeSemiAngle\>\"", "]"}], "]"}]}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"initialDisks", "=", 
        RowBox[{"<|", 
         RowBox[{"1", "->", 
          RowBox[{"<|", 
           RowBox[{
            RowBox[{"\"\<ID\>\"", "->", "1"}], ",", 
            RowBox[{"\"\<Disk\>\"", "->", 
             RowBox[{"Disk", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"0", ",", "d"}], "}"}], ",", 
               RowBox[{"arena", "[", "\"\<DiskRadius\>\"", "]"}]}], "]"}]}], 
            "\[IndentingNewLine]", ",", 
            RowBox[{"\"\<Polar\>\"", "->", 
             RowBox[{"<|", 
              RowBox[{
               RowBox[{"\"\<r\>\"", "->", "d"}], ",", 
               RowBox[{"\"\<\[Theta]\>\"", "->", 
                RowBox[{"\[Pi]", "/", "2"}]}]}], "|>"}]}], 
            "\[IndentingNewLine]", ",", 
            RowBox[{"\"\<Supporters\>\"", "->", 
             RowBox[{"Missing", "[", "]"}]}], "\[IndentingNewLine]", ",", 
            RowBox[{"\"\<EdgeDisk\>\"", "->", 
             RowBox[{"<|", 
              RowBox[{
               RowBox[{"\"\<Left\>\"", "->", "True"}], ",", 
               RowBox[{"\"\<Right\>\"", "->", "True"}]}], "|>"}]}], 
            "\[IndentingNewLine]", ",", 
            RowBox[{"\"\<CanSupportDisk\>\"", "->", 
             RowBox[{"<|", 
              RowBox[{
