Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"logStep", "[", 
    RowBox[{"run_", ",", "timing_"}], "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"res", ",", "thisLog", ",", "elapsed"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"res", "=", "run"}], ";", "\[IndentingNewLine]", 
      RowBox[{"thisLog", "=", 
       RowBox[{"res", "[", "\"\<Logging\>\"", "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"elapsed", "=", 
       RowBox[{"Round", "@", 
        RowBox[{"Abs", "@", 
         RowBox[{"DateDifference", "[", 
          RowBox[{"Now", ",", "globalTime", ",", "\"\<Second\>\""}], 
          "]"}]}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"thisLog", "[", "\"\<ElapsedSeconds\>\"", "]"}], "=", 
       RowBox[{"Round", "@", 
        RowBox[{"Abs", "@", 
         RowBox[{"DateDifference", "[", 
          RowBox[{"Now", ",", "globalTime", ",", "\"\<Second\>\""}], 
          "]"}]}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"thisLog", "[", "\"\<TimingMicroSeconds\>\"", "]"}], "=", 
       RowBox[{"Round", "[", 
        RowBox[{"1000", "*", "timing"}], "]"}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"thisLog", "[", "\"\<ID\>\"", "]"}], "=", 
       RowBox[{"run", "[", "\"\<ID\>\"", "]"}]}], ";", "\[IndentingNewLine]", 
      
      RowBox[{
       RowBox[{"thisLog", "[", "\"\<Disks\>\"", "]"}], "=", 
       RowBox[{"Append", "[", 
        RowBox[{
         RowBox[{"thisLog", "[", "\"\<Disks\>\"", "]"}], ",", 
         RowBox[{"run", "[", "\"\<Disks\>\"", "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"thisLog", "[", "\"\<ChainStore\>\"", "]"}], "=", 
       RowBox[{"Append", "[", 
        RowBox[{
         RowBox[{"thisLog", "[", "\"\<ChainStore\>\"", "]"}], ",", 
         RowBox[{"run", "[", "\"\<Chain\>\"", "]"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"res", "[", "\"\<Logging\>\"", "]"}], "=", "thisLog"}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"(*", " ", 
       RowBox[{
       "computeParastichy", " ", "needs", " ", "the", " ", "disks", " ", "in",
         " ", 
        RowBox[{
         RowBox[{"res", "[", "\"\<Logging\>\"", "]"}], "[", "\"\<Disks\>\"", 
         "]"}]}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"thisLog", "[", "\"\<ParastichyCount\>\"", "]"}], " ", "=", 
       RowBox[{"Append", "[", 
        RowBox[{
         RowBox[{"thisLog", "[", "\"\<ParastichyCount\>\"", "]"}], " ", ",", 
         RowBox[{
          RowBox[{"res", "[", "\"\<ID\>\"", "]"}], "->", 
          RowBox[{"computeParastichy", "[", "res", "]"}]}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"res", "[", "\"\<Logging\>\"", "]"}], "=", "thisLog"}], ";", 
      "\[IndentingNewLine]", "res"}]}], "\[IndentingNewLine]", "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"monitoringString", "[", "run_", "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
