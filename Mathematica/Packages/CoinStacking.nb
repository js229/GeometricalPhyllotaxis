Cell[CellGroupData[{

Cell["Compute disk distances", "Section",ExpressionUUID->"fd8b6d77-9297-2f4b-b3d8-fe848c07dba9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"tangentDiskCentres", "[", 
   RowBox[{"c1_List", ",", "c2_List", ",", "R_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "mid", ",", "diff", ",", "d", ",", "h", ",", "hSquared", ",", 
      "unitPerp"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{
     "1.", " ", "Vector", " ", "between", " ", "centers", " ", "and", " ", 
      "total", " ", "distance"}], "*)"}], "\[IndentingNewLine]", "\t", 
    RowBox[{
     RowBox[{"diff", "=", 
      RowBox[{"c2", "-", "c1"}]}], ";", "\n", 
     RowBox[{"(*", "\t", "If", 
      RowBox[{"[", 
       RowBox[{
        RowBox[{
         RowBox[{"diff", "[", 
          RowBox[{"[", "1", "]"}], "]"}], ">", "R"}], ",", 
        RowBox[{
         RowBox[{"Return", "[", 
          RowBox[{"Missing", "[", "]"}], "]"}], ";"}]}], 
       "\[IndentingNewLine]"}], "*)"}], "\t", 
     RowBox[{"d", "=", 
      RowBox[{"Norm", "[", "diff", "]"}]}], ";", "\[IndentingNewLine]", "\t", 
     
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Chop", "[", "d", "]"}], "==", "0"}], ",", 
       RowBox[{
        RowBox[{"Print", "[", 
         RowBox[{"\"\<tDC Identical \>\"", ",", "c1"}], "]"}], ";", 
        RowBox[{"Return", "[", 
         RowBox[{"Missing", "[", "\"\<Identical\>\"", "]"}], "]"}]}]}], "]"}],
      ";", "\[IndentingNewLine]", "\t", "\[IndentingNewLine]", "\t", 
     RowBox[{"(*", 
      RowBox[{
      "2.", " ", "Check", " ", "if", " ", "a", " ", "solution", " ", "exists",
        " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"distance", " ", "must", " ", "be"}], "<=", 
         RowBox[{"4", "R"}]}], ")"}]}], "*)"}], "\[IndentingNewLine]", "\t", 
     RowBox[{"hSquared", "=", 
      RowBox[{
       RowBox[{"4", "*", 
        RowBox[{"R", "^", "2"}]}], "-", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"d", "/", "2"}], ")"}], "^", "2"}]}]}], ";", 
     "\[IndentingNewLine]", "\t", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"hSquared", "<", "0"}], ",", "\[IndentingNewLine]", "\t", 
       RowBox[{"Return", "[", 
        RowBox[{"Missing", "[", "]"}], "]"}]}], "\[IndentingNewLine]", "\t", 
      "]"}], ";", "\[IndentingNewLine]", "\t", 
     RowBox[{"(*", 
      RowBox[{
      "3.", " ", "Midpoint", " ", "and", " ", "the", " ", "height", " ", "of",
        " ", "the", " ", "triangle", " ", "from", " ", "midpoint", " ", "to", 
       " ", "c3"}], "*)"}], "\[IndentingNewLine]", "\t", 
     RowBox[{"mid", "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"c1", "+", "c2"}], ")"}], "/", "2"}]}], ";", 
     "\[IndentingNewLine]", "\t", 
     RowBox[{"h", "=", 
      RowBox[{"Sqrt", "[", "hSquared", "]"}]}], ";", "\[IndentingNewLine]", 
     "\t", 
     RowBox[{"(*", 
      RowBox[{
      "4.", " ", "Find", " ", "the", " ", "unit", " ", "vector", " ", 
       "perpendicular", " ", "to", " ", "the", " ", "line", " ", "connecting",
        " ", "c1", " ", "and", " ", "c2"}], "*)"}], 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"Standard", " ", "2", "D", " ", 
        RowBox[{"rotation", ":", 
         RowBox[{"{", 
          RowBox[{"x", ",", "y"}], "}"}]}]}], "->", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "y"}], ",", "x"}], "}"}]}], "*)"}], 
     "\[IndentingNewLine]", "\t", 
     RowBox[{"unitPerp", "=", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"diff", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], ",", 
         RowBox[{"diff", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], "}"}], "/", "d"}]}], ";", 
     "\[IndentingNewLine]", "\t", 
     RowBox[{"(*", 
      RowBox[{
      "5.", " ", "Return", " ", "the", " ", "two", " ", "possible", " ", 
       "centers"}], "*)"}], "\[IndentingNewLine]", "\t", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"mid", "+", 
        RowBox[{"h", "*", "unitPerp"}]}], ",", 
       RowBox[{"mid", "-", 
        RowBox[{"h", "*", "unitPerp"}]}]}], "}"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Code",
 InitializationCell->True,
 CellLabel->"In[94]:=",ExpressionUUID->"367c735a-29ec-a740-b1de-f29038a37faa"]
}, Open  ]]
