      RowBox[{"Print", "[", 
       RowBox[{"\"\<uC fDL supporters \>\"", ",", "supporters", 
        ",", "\"\< not in \>\"", ",", "chainNumbers"}], "]"}], ";", 
      RowBox[{"Abort", "[", "]"}], ";"}]}], "\n", "\t\t", "\n", "\t\t", 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"fixDoubleRight", "[", 
    RowBox[{"chain_", ",", "ID_", ",", "supporters_"}], "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
