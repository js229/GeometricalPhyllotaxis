Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"inConeType", "[", 
     RowBox[{"arena_", ",", "diskData_"}], "]"}], " ", ":=", " ", 
    RowBox[{"Which", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"diskData", "[", "\"\<Polar\>\"", "]"}], 
        "[", "\"\<\[Theta]\>\"", "]"}], " ", "<", " ", 
       RowBox[{
        RowBox[{"\[Pi]", "/", "2"}], " ", "-", "  ", 
        RowBox[{"arena", "[", "\"\<ConeSemiAngle\>\"", "]"}]}]}], " ", 
      ",", "\"\<Right\>\"", ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"diskData", "[", "\"\<Polar\>\"", "]"}], 
        "[", "\"\<\[Theta]\>\"", "]"}], " ", ">", " ", 
       RowBox[{
        RowBox[{"\[Pi]", "/", "2"}], " ", "+", "  ", 
        RowBox[{"arena", "[", "\"\<ConeSemiAngle\>\"", "]"}]}]}], " ", 
      ",", "\"\<Left\>\"", ",", "\[IndentingNewLine]", "True", 
      ",", "\"\<Centre\>\""}], "]"}]}], "\[IndentingNewLine]"}]}]], "Code",
 InitializationCell->True,
 CellLabel->"In[65]:=",ExpressionUUID->"27f5a35c-f38c-c84b-ba3e-b7dc0ef060f2"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"segment", "[", 
     RowBox[{"arena_", ",", "polar_"}], "]"}], " ", ":=", " ", 
    RowBox[{"Circle", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", "0"}], "}"}], ",", 
      RowBox[{"polar", "[", "\"\<r\>\"", "]"}], ",", 
      RowBox[{"{", 
       RowBox[{
