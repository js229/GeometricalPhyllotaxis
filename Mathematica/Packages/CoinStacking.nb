Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"addLowest", "[", "run_", "]"}], " ", ":=", " ", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "res", ",", "ixPairs", ",", "ID", ",", "ids", ",", "diskData", ",", 
         "disks", ",", "timing", ",", "monitorResults"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"res", "=", "run"}], ";", "\[IndentingNewLine]", 
        RowBox[{"ID", "=", 
         RowBox[{
          RowBox[{"run", "[", "\"\<ID\>\"", "]"}], "+", "1"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"res", "[", "\"\<ID\>\"", "]"}], "=", "ID"}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"timing", ",", "diskData"}], "}"}], "=", 
         RowBox[{"Timing", "[", 
          RowBox[{"lowestTangentDiskFromPairs", "[", 
           RowBox[{"res", ",", "ID"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"res", "[", "\"\<Disks\>\"", "]"}], "=", " ", 
         RowBox[{"addDisk", "[", 
          RowBox[{
           RowBox[{"res", "[", "\"\<Arena\>\"", "]"}], ",", 
           RowBox[{"res", "[", "\"\<Disks\>\"", "]"}], ",", "diskData", ",", 
           "ID"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"res", "[", "\"\<Chain\>\"", "]"}], "=", " ", 
         RowBox[{"updateChain", "[", 
          RowBox[{"res", ",", "diskData"}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"clearOldDisksFromCache", "[", "res", "]"}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{
          "if", " ", "the", " ", "new", " ", "disk", " ", "has", " ", "a", " ",
            "supporter", " ", "which", " ", "is", " ", "a", " ", 
           RowBox[{"left", "[", "n", "]"}], " ", "or", " ", 
           RowBox[{"right", "[", "n", "]"}], " ", "that", " ", "might", " ", 
           "not", " ", "have", " ", "been", " ", "in", " ", "the", " ", 
           "Disks", " ", "before"}], ",", " ", 
          RowBox[{
          "because", " ", "it", " ", "was", " ", "only", " ", "there", " ", 
           "as", " ", "n"}]}], "   ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"ids", "=", 
         RowBox[{"Complement", "[", 
          RowBox[{
           RowBox[{"res", "[", "\"\<Chain\>\"", "]"}], ",", 
           RowBox[{"Keys", "[", 
            RowBox[{"res", "[", "\"\<Disks\>\"", "]"}], "]"}]}], "]"}]}], ";",
         "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"res", "[", "\"\<Disks\>\"", "]"}], "=", 
         RowBox[{"Fold", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"addLRDisk", "[", 
             RowBox[{
              RowBox[{"res", "[", "\"\<Arena\>\"", "]"}], ",", "#1", ",", 
              "#2"}], "]"}], "&"}], ",", 
           RowBox[{"res", "[", "\"\<Disks\>\"", "]"}], ",", "ids"}], "]"}]}], 
        ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"res", "=", 
         RowBox[{"logStep", "[", 
          RowBox[{"res", ",", "timing"}], "]"}]}], ";", "\[IndentingNewLine]",
         "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{"having", " ", "logged", " ", "past", " ", "disks"}], ",", 
          " ", 
          RowBox[{
          "only", " ", "use", " ", "current", " ", "chain", " ", "for", " ", 
           "lookup"}]}], " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"res", "[", "\"\<Disks\>\"", "]"}], "=", 
         RowBox[{"KeyTake", "[", 
          RowBox[{
           RowBox[{"res", "[", "\"\<Disks\>\"", "]"}], ",", 
           RowBox[{"Append", "[", 
            RowBox[{
             RowBox[{"res", "[", "\"\<Chain\>\"", "]"}], ",", "ids"}], 
            "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
        "\[IndentingNewLine]", 
        RowBox[{"monitorString", "=", 
         RowBox[{"monitoringString", "[", "res", "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", "res"}]}], 
      "\[IndentingNewLine]", "\[IndentingNewLine]", "]"}]}], ";"}], 
   "\[IndentingNewLine]"}]}]], "Code",
