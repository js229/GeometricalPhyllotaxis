Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"testArena", "[", "n_", "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"arena", ",", "\[Theta]"}], "}"}], ",", "\[IndentingNewLine]", 
      "\t", 
      RowBox[{
       RowBox[{"\[Theta]", "=", 
        RowBox[{"N", "[", 
         RowBox[{"\[Pi]", "/", "8"}], "]"}]}], ";", "\[IndentingNewLine]", 
       "\t", 
       RowBox[{"arena", "=", 
        RowBox[{"<|", "\[IndentingNewLine]", "\t\t", 
         RowBox[{
          RowBox[{"\"\<Type\>\"", "->", "\"\<Cone\>\""}], ",", 
          "\[IndentingNewLine]", "\t\t", 
          RowBox[{"\"\<DiskRadius\>\"", "->", "1"}], ",", 
          "\[IndentingNewLine]", "\t\t", 
          RowBox[{"\"\<ConeSemiAngle\>\"", "->", "\[Theta]"}], ",", "\n", 
          "\t\t", 
          RowBox[{"\"\<LeftRotationMatrix\>\"", "->", 
           RowBox[{"RotationMatrix", "[", 
            RowBox[{"2", " ", "\[Theta]"}], "]"}]}], ",", "\n", "\t\t", 
          RowBox[{"\"\<RightRotationMatrix\>\"", "->", 
           RowBox[{"RotationMatrix", "[", 
            RowBox[{
             RowBox[{"-", "2"}], " ", "\[Theta]"}], "]"}]}], ",", 
          "\[IndentingNewLine]", "\t\t", 
          RowBox[{"\"\<Edges\>\"", "->", 
           RowBox[{"<|", 
            RowBox[{
             RowBox[{"\"\<Left\>\"", "->", 
              RowBox[{"InfiniteLine", "[", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"0", ",", "0"}], "}"}], ",", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"-", 
                    RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", 
                   RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}], "}"}], 
               "]"}]}], ",", 
             RowBox[{"\"\<Right\>\"", "->", 
              RowBox[{"InfiniteLine", "[", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"0", ",", "0"}], "}"}], ",", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"Sin", "[", "\[Theta]", "]"}], ",", 
                   RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}], "}"}], 
               "]"}]}]}], "|>"}]}], ",", "\[IndentingNewLine]", "\t\t", 
          RowBox[{"\"\<zRange\>\"", "->", 
           RowBox[{"{", 
            RowBox[{"0", ",", "30"}], "}"}]}], ",", "\[IndentingNewLine]", 
          "\t\t", 
          RowBox[{"\"\<IDmax\>\"", "->", "n"}]}], "\[IndentingNewLine]", "\t",
          "|>"}]}], ";", "\[IndentingNewLine]", "\t", "arena"}]}], 
     "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]"}]], "Code",
 InitializationCell->True,
 CellLabel->"In[3]:=",ExpressionUUID->"c2924e34-f199-8248-abd3-eb73c1ffd8f4"],

Cell[BoxData[
 RowBox[{
  RowBox[{"doParameterisedRun", "[", "arena_", "]"}], " ", ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"runDisks", "=", 
      RowBox[{"initalizeDisks", "[", "arena", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"runChain", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"left", "[", "1", "]"}], ",", "1", ",", 
        RowBox[{"right", "[", "1", "]"}]}], "}"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"run", "=", 
      RowBox[{"<|", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"\"\<Arena\>\"", "->", "arena"}], ",", "\[IndentingNewLine]", 
        
        RowBox[{"\"\<Disks\>\"", "->", "runDisks"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"\"\<Chain\>\"", "->", "runChain"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"\"\<ID\>\"", "->", "1"}], ",", "\[IndentingNewLine]", 
        RowBox[{"\"\<Logging\>\"", "->", 
         RowBox[{"<|", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"\"\<ID\>\"", "->", "1"}], ",", "\[IndentingNewLine]", 
           RowBox[{"\"\<Disks\>\"", "->", 
            RowBox[{"<|", "|>"}]}], ",", "\[IndentingNewLine]", 
           RowBox[{"\"\<ChainStore\>\"", "->", 
            RowBox[{"{", "runChain", "}"}]}], ",", "\[IndentingNewLine]", 
           RowBox[{"\"\<ParastichyCount\>\"", "->", 
            RowBox[{"<|", 
             RowBox[{"1", "->", 
              RowBox[{"<|", 
               RowBox[{
                RowBox[{"\"\<Up\>\"", "->", "1"}], ",", 
                RowBox[{"\"\<Down\>\"", "->", "1"}]}], "|>"}]}], "|>"}]}], ",",
            "\[IndentingNewLine]", 
           RowBox[{"\"\<rMax\>\"", "->", "\"\<Missing\>\""}]}], 
          "\[IndentingNewLine]", "|>"}]}]}], "\[IndentingNewLine]", "|>"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"globalTime", "=", "Now"}], ";", "\[IndentingNewLine]", 
     RowBox[{"run", "=", 
      RowBox[{"logStep", "[", 
       RowBox[{"run", ",", "0"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"run", "=", 
      RowBox[{"restartRun", "[", "run", "]"}]}], ";", "\[IndentingNewLine]", 
     "run"}]}], "\[IndentingNewLine]", "]"}]}]], "Code",
 InitializationCell->True,
 CellLabel->"In[4]:=",ExpressionUUID->"48ef3d46-2241-794c-8678-8b2b746f3bb8"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"restartRun", "[", "lastRun_", "]"}], " ", ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"run", "=", "lastRun"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"run", "[", "\"\<Logging\>\"", "]"}], "[", "\"\<Disks\>\"", 
       "]"}], "=", 
      RowBox[{"<|", "|>"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"run", "[", "\"\<Logging\>\"", "]"}], "[", "\"\<ChainStore\>\"",
        "]"}], " ", "=", " ", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"globalTime", "=", "Now"}], ";", "\[IndentingNewLine]", 
     RowBox[{"globalTangentDiskCache", "=", 
      RowBox[{"<|", "|>"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"monitorString", "=", "\"\<Restart\>\""}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"run", "=", 
      RowBox[{"Monitor", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"NestWhile", "[", "\[IndentingNewLine]", 
         RowBox[{
         "addLowest", ",", "run", ",", "continueCondition", ",", "1", ",", 
          RowBox[{"maxIterations", "=", "1000"}]}], "]"}], ",", 
        "monitorString"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "monitorString", "]"}], ";", "\[IndentingNewLine]",
      "run"}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"continueCondition", "[", "run_", "]"}], " ", ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "diskID", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"diskID", "=", 
      RowBox[{"Max", "[", 
       RowBox[{"Select", "[", 
        RowBox[{
         RowBox[{"Keys", "[", 
          RowBox[{"run", "[", "\"\<Disks\>\"", "]"}], "]"}], ",", "NumberQ"}],
         "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"diskID", ">=", " ", 
        RowBox[{
         RowBox[{"run", "[", "\"\<Arena\>\"", "]"}], "[", "\"\<IDmax\>\"", 
         "]"}]}], ",", " ", 
       RowBox[{"Return", "[", "False", "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", "True", "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]}], "Code",
 InitializationCell->True,
