              "supporters", "\[LeftDoubleBracket]", "1", 
               "\[RightDoubleBracket]"}], ",", "ID"}], "}"}], ",", 
            "chainNumbers"}], "]"}]}], ";", "\n", "\t\t\t", 
         RowBox[{"Return", "[", "chainNumbers", "]"}]}]}], "\n", "\t\t", 
