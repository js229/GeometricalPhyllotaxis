Cell[CellGroupData[{

Cell["Compute parastichies for logging", "Section",ExpressionUUID->"436509d3-47dc-d145-b9e0-ae7a83cde751"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"computeParastichy", "[", "run_", "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"edges", ",", "res"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"edges", "=", 
       RowBox[{"chainEdges", "[", 
        RowBox[{"run", ",", 
         RowBox[{"Drop", "[", 
          RowBox[{
           RowBox[{"run", "[", "\"\<Chain\>\"", "]"}], ",", 
           RowBox[{"-", "1"}]}], "]"}]}], "]"}]}], ";", "\[IndentingNewLine]",
       "\[IndentingNewLine]", 
      RowBox[{"res", "=", 
       RowBox[{"parastichyCount", "[", 
        RowBox[{"Values", "[", "edges", "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", "res"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Code",
 InitializationCell->True,
 CellLabel->"In[86]:=",ExpressionUUID->"4e8ac3d9-79eb-2f42-b562-dd2a2efa4e85"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"chainEdges", "[", 
     RowBox[{"run_", ",", "chain_"}], "]"}], " ", ":=", "  ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"edges", ",", "graph", ",", "pairs", ",", "nodes"}], "}"}], ",",
       "\[IndentingNewLine]", "\t", 
      RowBox[{
       RowBox[{"pairs", "=", 
        RowBox[{"Partition", "[", 
         RowBox[{"chain", ",", "2", ",", "1"}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\t", 
       RowBox[{"edges", "=", 
        RowBox[{"Map", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Apply", "[", 
            RowBox[{"UndirectedEdge", ",", "#"}], "]"}], "&"}], ",", 
          "pairs"}], "]"}]}], ";", "\[IndentingNewLine]", "\t", 
       RowBox[{"edges", "=", 
        RowBox[{"Association", "@", 
         RowBox[{"Map", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"#", "->", 
             RowBox[{"orientation", "[", 
              RowBox[{"run", ",", "#"}], "]"}]}], "&"}], ",", "edges"}], 
          "]"}]}]}]}]}], "\[IndentingNewLine]", "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"orientation", "[", 
     RowBox[{"run_", ",", 
      RowBox[{"a_", " ", "\[UndirectedEdge]", " ", "b_"}]}], "]"}], " ", ":=",
     " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"sca", ",", "scb"}], "}"}], ",", "\n", "\t", 
      RowBox[{
       RowBox[{"sca", "=", 
        RowBox[{"diskSurfaceCoordinates", "[", 
         RowBox[{"run", ",", "a", ",", "\"\<UseLogged\>\""}], "]"}]}], ";", 
       "\n", "\t", 
       RowBox[{"scb", "=", 
        RowBox[{"diskSurfaceCoordinates", "[", 
         RowBox[{"run", ",", "b", ",", "\"\<UseLogged\>\""}], "]"}]}], ";", 
       "\n", "\t", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"sca", ",", "scb"}], "}"}], "=", 
        RowBox[{"SortBy", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"sca", ",", "scb"}], "}"}], ",", 
          RowBox[{"#Azimuth", "&"}]}], "]"}]}], ";", "\n", "\t", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"sca", "[", "\"\<Meridian\>\"", "]"}], ">", 
          RowBox[{"scb", "[", "\"\<Meridian\>\"", "]"}]}], ",", "\"\<Up\>\"", 
         ",", "\"\<Down\>\""}], "]"}]}]}], "\n", "\t", "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"orientationStyle", "[", "\"\<Up\>\"", "]"}], ":=", " ", 
   "StandardRed"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"orientationStyle", "[", "\"\<Down\>\"", "]"}], ":=", " ", 
   "StandardBlue"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"orientationStyle", "[", "x_", "]"}], " ", ":=", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Print", "[", "x", "]"}], ";", 
      RowBox[{"{", "}"}]}], ")"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"parastichyCount", "[", "updowns_", "]"}], " ", ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "res", "}"}], ",", "\[IndentingNewLine]", "\t", 
    RowBox[{
     RowBox[{"res", "=", " ", "updowns"}], ";", "\[IndentingNewLine]", "\t", 
     RowBox[{"res", "=", 
      RowBox[{"Counts", "[", 
       RowBox[{"updowns", ",", 
        RowBox[{"{", 
         RowBox[{"\"\<Up\>\"", ",", "\"\<Down\>\""}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\t", "res"}]}], "\[IndentingNewLine]", 
   "]"}]}], "\[IndentingNewLine]"}], "Code",
 InitializationCell->True,
 CellChangeTimes->{{3.9842206874404564`*^9, 3.9842206904094334`*^9}, {
  3.98439543029636*^9, 3.984395541627201*^9}, {3.9843955732891846`*^9, 
  3.9843957234487915`*^9}},ExpressionUUID->"5d76d568-a332-1446-a49a-\
