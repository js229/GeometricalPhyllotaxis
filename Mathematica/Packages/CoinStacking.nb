       "\[IndentingNewLine]", "\"\< `ID` \\t`Parastichy pair` \\tElapsed \
`ElapsedSeconds`\\tTiming `TimingMicroSeconds`\>\"", "]"}], 
      "\[IndentingNewLine]", "[", 
