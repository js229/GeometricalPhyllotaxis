Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"printRun", "[", "run_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"labels", ",", "diskGraph", ",", "chainGraph", ",", "arena"}], 
      "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"disks", "=", 
       RowBox[{
        RowBox[{"#Disk", "&"}], "/@", " ", 
        RowBox[{
         RowBox[{"run", "[", "\"\<Logging\>\"", "]"}], "[", "\"\<Disks\>\"", 
         "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"chainGraph", "=", 
       RowBox[{"makeChainGraph", "[", "run", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"arena", "=", 
       RowBox[{"run", "[", "\"\<Arena\>\"", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Show", "[", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Graphics", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"FaceForm", "[", "LightGray", "]"}], ",", 
           RowBox[{"EdgeForm", "[", "None", "]"}], ",", "\[IndentingNewLine]", 
           RowBox[{"displayPrintCone", "[", "arena", "]"}]}], "}"}], "]"}], ",",
         "\[IndentingNewLine]", 
        RowBox[{"Graphics", "\[IndentingNewLine]", "[", 
         RowBox[{"{", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"FaceForm", "[", "White", "]"}], ",", 
            RowBox[{"EdgeForm", "[", "None", "]"}], ",", 
            RowBox[{"Values", "[", "disks", "]"}]}], "}"}], 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{"displayDiskNumbers", "[", 
            RowBox[{"arena", ",", "disks", ",", 
             RowBox[{"Keys", "[", "disks", "]"}]}], "]"}], 
           "\[IndentingNewLine]", "*)"}], "}"}], "]"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"makeGraph", "[", "run", "]"}], ",", "\[IndentingNewLine]", 
        RowBox[{"Graphics", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"FaceForm", "[", "None", "]"}], ",", 
           RowBox[{"EdgeForm", "[", "Black", "]"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"displayPrintConeBoundary", "[", "arena", "]"}]}], "}"}], 
         "]"}]}], "\[IndentingNewLine]", "]"}]}]}], "\[IndentingNewLine]", 
    "]"}]}]}]], "Input",
