Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"displayPrintCone", "[", "arena_", "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"zLimit", ",", "xLimit"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"zLimit", "=", "29"}], ";", "\[IndentingNewLine]", 
      RowBox[{"xLimit", "=", 
       RowBox[{"zLimit", " ", 
        RowBox[{"Tan", "[", 
         RowBox[{"arena", "[", "\"\<ConeSemiAngle\>\"", "]"}], "]"}]}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"DiscretizeRegion", "@", 
       RowBox[{"RegionDifference", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Disk", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0", ",", "0"}], "}"}], ",", "zLimit", ",", 
           RowBox[{
            RowBox[{"\[Pi]", "/", "2"}], "+", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", 
               RowBox[{"arena", "[", "\"\<ConeSemiAngle\>\"", "]"}]}], ",", 
              RowBox[{"arena", "[", "\"\<ConeSemiAngle\>\"", "]"}]}], 
             "}"}]}]}], "]"}], ",", "\[IndentingNewLine]", 
         RowBox[{"Disk", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0", ",", "0"}], "}"}], ",", "2"}], "]"}]}], "]"}]}]}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"displayPrintConeBoundary", "[", "arena_", "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"zLimit", ",", "xLimit"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"zLimit", "=", "29"}], ";", "\[IndentingNewLine]", 
      RowBox[{"xLimit", "=", 
       RowBox[{"zLimit", " ", 
        RowBox[{"Tan", "[", 
         RowBox[{"arena", "[", "\"\<ConeSemiAngle\>\"", "]"}], "]"}]}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"DiscretizeRegion", "@", 
       RowBox[{"RegionBoundary", "@", 
        RowBox[{"RegionDifference", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Disk", "[", 
           RowBox[{
            RowBox[{"{", 
