     RowBox[{
      RowBox[{"{", "}"}], ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"disks", "=", 
        RowBox[{"Values", "[", 
         RowBox[{
          RowBox[{"run", "[", "\"\<Logging\>\"", "]"}], "[", "\"\<Disks\>\"", 
          "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"leftEdgeDisks", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"leftShift", "[", 
           RowBox[{
            RowBox[{"run", "[", "\"\<Arena\>\"", "]"}], ",", "#"}], "]"}], 
          "&"}], "/@", 
         RowBox[{"Select", "[", 
          RowBox[{"disks", ",", 
           RowBox[{
            RowBox[{
             RowBox[{"NumberQ", "[", "#ID", "]"}], "&&", " ", 
             RowBox[{"TrueQ", "[", 
              RowBox[{"#CanSupportDisk", "[", "\"\<Right\>\"", "]"}], "]"}]}],
             "&"}]}], "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"rightEdgeDisks", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"rightShift", "[", 
           RowBox[{
            RowBox[{"run", "[", "\"\<Arena\>\"", "]"}], ",", "#"}], "]"}], 
          "&"}], "/@", 
         RowBox[{"Select", "[", 
          RowBox[{"disks", ",", 
           RowBox[{
            RowBox[{
             RowBox[{"NumberQ", "[", "#ID", "]"}], "&&", 
             RowBox[{"TrueQ", "[", 
              RowBox[{"#CanSupportDisk", "[", "\"\<Left\>\"", "]"}], "]"}]}], 
            "&"}]}], "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"visibleDisks", "=", 
        RowBox[{"Join", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Select", "[", 
           RowBox[{"disks", ",", 
            RowBox[{
             RowBox[{"NumberQ", "[", "#ID", "]"}], "&"}]}], "]"}], ",", 
          "\[IndentingNewLine]", "leftEdgeDisks", ",", "\[IndentingNewLine]", 
          "rightEdgeDisks"}], "]"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"croppedDisks", "=", 
        RowBox[{"Map", "[", 
         RowBox[{
