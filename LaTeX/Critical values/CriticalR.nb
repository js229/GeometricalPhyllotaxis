Cell["Cone parameters", "Section",ExpressionUUID->"842d2bf8-c844-204a-9d83-f51e06f2d0a1"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"SetDirectory", "[", 
    RowBox[{"NotebookDirectory", "[", "]"}], "]"}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"criticalConeArena", "[", 
    RowBox[{"runID_", ",", "\[Theta]_", ",", "finalChainLength_"}], "]"}], 
   " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "arena", ",", "displayZ", ",", "displayConeArcLength", ",", 
       "displayX"}], "}"}], ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
      "length", " ", "of", " ", "topmost", " ", "chain", " ", "is", "  ", 
       "coneArcLength", " ", "*", " ", "2", " ", "conesemiAngle"}], " ", 
      "*)"}], "\[IndentingNewLine]", "\t", 
     RowBox[{
      RowBox[{"displayConeArcLength", "=", 
       RowBox[{"finalChainLength", " ", "/", 
        RowBox[{"(", 
         RowBox[{"2", " ", "\[Theta]"}], ")"}]}]}], ";", "\n", "\t", 
      RowBox[{"displayZ", "=", 
       RowBox[{"displayConeArcLength", "*", 
        RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], ";", "\n", "\t", 
      RowBox[{"displayX", "=", 
       RowBox[{"displayConeArcLength", "*", 
        RowBox[{"Sin", "[", "\[Theta]", "]"}]}]}], ";", "\[IndentingNewLine]",
       "\[IndentingNewLine]", "\t", 
      RowBox[{"arena", "=", 
       RowBox[{"<|", "\n", "\t\t", 
        RowBox[{
         RowBox[{"\"\<RunID\>\"", "->", "runID"}], ",", "\[IndentingNewLine]",
          "\t\t", 
         RowBox[{"\"\<Type\>\"", "->", "\"\<Cone\>\""}], ",", 
         "\[IndentingNewLine]", "\t\t", 
         RowBox[{"\"\<DiskRadius\>\"", "->", "1"}], ",", "\n", "\t\t", 
         RowBox[{"\"\<ConeSemiAngle\>\"", "->", "\[Theta]"}], ",", "\n", 
         "\t\t", 
         RowBox[{"\"\<LeftRotationMatrix\>\"", "->", 
          RowBox[{"RotationMatrix", "[", 
           RowBox[{"2", " ", "\[Theta]"}], "]"}]}], ",", "\n", "\t\t", 
         RowBox[{"\"\<RightRotationMatrix\>\"", "->", 
          RowBox[{"RotationMatrix", "[", 
           RowBox[{
            RowBox[{"-", "2"}], " ", "\[Theta]"}], "]"}]}], ",", 
         "\[IndentingNewLine]", "\t\t", 
         RowBox[{"\"\<Edges\>\"", "->", 
          RowBox[{"<|", 
           RowBox[{
            RowBox[{"\"\<Left\>\"", "->", 
             RowBox[{"InfiniteLine", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"0", ",", "0"}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"-", 
                   RowBox[{"Sin", "[", "\[Theta]", "]"}]}], ",", 
                  RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}], "}"}], 
              "]"}]}], ",", 
            RowBox[{"\"\<Right\>\"", "->", 
             RowBox[{"InfiniteLine", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"0", ",", "0"}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"Sin", "[", "\[Theta]", "]"}], ",", 
                  RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}], "}"}], 
              "]"}]}]}], "|>"}]}], ",", "\[IndentingNewLine]", "\t\t", 
         RowBox[{"\"\<zRange\>\"", "->", 
          RowBox[{"{", 
           RowBox[{"0", ",", "displayZ"}], "}"}]}], ",", "\n", "\t\t", 
         RowBox[{"\"\<Monitoring\>\"", "->", "True"}], ",", "\n", "\t\t", 
         RowBox[{"\"\<DisplayRegion\>\"", "->", 
          RowBox[{"Disk", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", "0"}], "}"}], ",", "displayConeArcLength", ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{
               RowBox[{"\[Pi]", "/", "2"}], "-", "\[Theta]"}], ",", 
              RowBox[{
               RowBox[{"\[Pi]", "/", "2"}], "+", "\[Theta]"}]}], "}"}]}], 
           "]"}]}], ",", "\n", "\t\t", 
         RowBox[{"\"\<RandomizationSeed\>\"", "->", " ", 
          RowBox[{"Missing", "[", "]"}]}], ",", "\n", "\t\t", 
         RowBox[{"\"\<StoppingFunction\>\"", "->", " ", 
          RowBox[{"Function", "[", 
           RowBox[{"run", ",", 
            RowBox[{
             RowBox[{
              RowBox[{"run", "[", "\"\<ID\>\"", "]"}], ">", "10000"}], "\n", 
             "\t\t", "||", " ", 
             RowBox[{
              RowBox[{"Max", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"#Polar", "[", "\"\<r\>\"", "]"}], "&"}], "/@", 
                RowBox[{"run", "[", "\"\<Disks\>\"", "]"}]}], "]"}], ">", 
              "displayConeArcLength"}]}]}], "]"}]}]}], "\[IndentingNewLine]", 
        "\t", "|>"}]}], ";", "\n", "\t", 
      RowBox[{"arena", " ", "=", 
       RowBox[{"addInitialDisks", "[", "arena", "]"}]}], ";", "\n", "\t", 
      "arena"}]}], "\n", "\t", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"\t"}]}], "Code",
