Cell[BoxData[
 RowBox[{
  RowBox[{"displayConeRun", "[", "run_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "lines", ",", "topChainLines", ",", "disks", ",", "styledDisks", ",", 
      "rMinMax"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"disks", "=", " ", 
      RowBox[{"Values", "@", 
       RowBox[{
        RowBox[{"run", "[", "\"\<Logging\>\"", "]"}], "[", "\"\<Disks\>\"", 
        "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"rMinMax", "=", 
      RowBox[{"MinMax", "[", 
       RowBox[{"Map", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"#Polar", "[", "\"\<r\>\"", "]"}], "&"}], ",", "disks"}], 
        "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"rMinMax", "=", 
      RowBox[{"rMinMax", "+", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{
           RowBox[{"run", "[", "\"\<Arena\>\"", "]"}], 
           "[", "\"\<DiskRadius\>\"", "]"}]}], ",", 
         RowBox[{
          RowBox[{"run", "[", "\"\<Arena\>\"", "]"}], 
          "[", "\"\<DiskRadius\>\"", "]"}]}], "}"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"xMax", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"rMinMax", "[", 
         RowBox[{"[", "2", "]"}], "]"}], "*", " ", 
        RowBox[{"Sin", "[", 
         RowBox[{
          RowBox[{"run", "[", "\"\<Arena\>\"", "]"}], 
          "[", "\"\<ConeSemiAngle\>\"", "]"}], "]"}]}], "+", 
       RowBox[{
        RowBox[{"run", "[", "\"\<Arena\>\"", "]"}], "[", "\"\<DiskRadius\>\"",
         "]"}]}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"styledDisks", "=", " ", 
      RowBox[{"diskClassify", "[", "run", "]"}]}], ";", "\[IndentingNewLine]",
      "\[IndentingNewLine]", 
     RowBox[{"lines", "=", 
      RowBox[{"makeLines", "[", "run", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"topChainLines", "=", 
      RowBox[{"makeTopChainLine", "[", "run", "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"graphics", "=", "\[IndentingNewLine]", 
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"displayCone", "[", 
