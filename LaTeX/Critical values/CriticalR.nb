Cell[BoxData[
 RowBox[{
  RowBox[{"displayCylinderRun", "[", "run_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "cylinder", ",", "lines", ",", "topChainLines", ",", "disks", ",", 
      "styledDisks", ",", "halfWidth", ",", "diskCentres", ",", "zRange"}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"cylinder", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"FaceForm", "[", "LightGreen", "]"}], ",", 
        RowBox[{"EdgeForm", "[", "None", "]"}], ",", 
        RowBox[{
         RowBox[{"run", "[", "\"\<Arena\>\"", "]"}], 
         "[", "\"\<DisplayRegion\>\"", "]"}]}], "}"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"halfWidth", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"run", "[", "\"\<Arena\>\"", "]"}], 
        "[", "\"\<CylinderCircumference\>\"", "]"}], "/", "2"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"disks", "=", " ", 
      RowBox[{"Values", "[", 
       RowBox[{
        RowBox[{"run", "[", "\"\<Logging\>\"", "]"}], "[", "\"\<Disks\>\"", 
        "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"diskCentres", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"diskCentre", "[", "#Disk", "]"}], "&"}], "/@", "disks"}]}], ";",
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"zRange", "=", 
      RowBox[{"MinMax", "[", 
       RowBox[{"Last", "/@", "diskCentres"}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"styledDisks", "=", " ", 
      RowBox[{"diskClassify", "[", "run", "]"}]}], ";", "\[IndentingNewLine]",
      "\[IndentingNewLine]", 
     RowBox[{"lines", "=", 
      RowBox[{"makeLines", "[", "run", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"topChainLines", "=", 
      RowBox[{"makeTopChainLine", "[", "run", "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
