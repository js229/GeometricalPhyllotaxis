Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"zLoggingHeight", "[", 
    RowBox[{"run_", ",", "id_"}], "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"res", ",", "mrd"}], "}"}], ",", "\n", "\t", 
     RowBox[{
      RowBox[{"mrd", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"run", "[", "\"\<Logging\>\"", "]"}], "[", "\"\<Disks\>\"", 
         "]"}], "[", "id", "]"}]}], ";", "\n", "\t", 
      RowBox[{"res", "=", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"arenaConeQ", "[", 
          RowBox[{"run", "[", "\"\<Arena\>\"", "]"}], "]"}], ",", "\n", 
         "\t\t", 
         RowBox[{
          RowBox[{"mrd", "[", "\"\<Polar\>\"", "]"}], "[", "\"\<r\>\"", "]"}],
          "\n", "\t\t", ",", "\n", "\t\t", 
         RowBox[{
          RowBox[{"diskCentre", "[", 
           RowBox[{"mrd", "[", "\"\<Disk\>\"", "]"}], "]"}], "[", 
          RowBox[{"[", "2", "]"}], "]"}]}], "\n", "\t\t", "]"}]}], ";", "\n", 
      "\t", "res"}]}], "\n", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"zScaledHeight", "[", 
    RowBox[{"run_", ",", "id_"}], "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "res", "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"res", "=", 
       RowBox[{"zLoggingHeight", "[", 
        RowBox[{"run", ",", "id"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"arenaCylinderQ", "[", 
         RowBox[{"run", "[", "\"\<Arena\>\"", "]"}], "]"}], ",", 
        RowBox[{"Return", "[", "res", "]"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"res", "=", " ", 
       RowBox[{"res", " ", "*", " ", 
        RowBox[{
         RowBox[{"run", "[", "\"\<Arena\>\"", "]"}], 
